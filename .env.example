# ClipMind Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Application Environment: development | beta | production
APP_ENV=development

# --- AI API Keys ---
# Gemini API key (or set OPENAI_API_KEY for OpenAI)
GEMINI_API_KEY=

# --- YouTube OAuth ---
# Obtain from Google Cloud Console > APIs & Services > Credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/callback

# --- Security ---
# Fernet encryption key for OAuth token storage.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In development, auto-generated if missing. In production, MUST be pre-set.
ENCRYPTION_KEY=

# --- CORS ---
# Comma-separated list of allowed origins.
# Development: http://localhost:8000,http://127.0.0.1:8000
# Beta:        https://beta.clipmind.app
# Production:  https://app.clipmind.app
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- HTTPS ---
# Set to true in beta/production behind a reverse proxy with TLS termination.
ENFORCE_HTTPS=false

# --- Database ---
# Development: sqlite:///output/analytics.db
# Production:  postgresql://user:password@host:5432/clipmind
DATABASE_URL=sqlite:///output/analytics.db

# --- Custom Like Overlay Keying Settings ---
# Background color to key out (e.g. white, black, green, or hex 0xFFFFFF)
LIKE_OVERLAY_KEY_COLOR=white
# Similarity tolerance (0.01 matches only the exact color, 1.0 matches everything)
LIKE_OVERLAY_SIMILARITY=0.01
# Blend percentage for soft/feathered keying boundaries (0.0 is hard, 0.1 is very soft)
LIKE_OVERLAY_BLEND=0.05
# --- Video Processing Options ---
# Upscale mode: Off | 2x AI Upscale | 4K AI Upscale | 8K AI Upscale
VIDEO_UPSCALE_MODE=Off
